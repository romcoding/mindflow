# ─────────────────────────────────────────────────────────────────────
# MindFlow / Rovot — Environment Configuration
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_DB=mindflow
POSTGRES_USER=mindflow
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
DATABASE_URL=postgresql://mindflow:CHANGE_ME_TO_A_STRONG_PASSWORD@db:5432/mindflow

# ── Authentication ───────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"

# ── LLM Provider ────────────────────────────────────────────────────
# Options: openai, lmstudio, ollama, custom
LLM_PROVIDER=openai

# OpenAI (required for LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_BASE=

# LM Studio (set LLM_PROVIDER=lmstudio)
# OPENAI_API_BASE=http://localhost:1234/v1
# LLM_MODEL=local-model

# Ollama (set LLM_PROVIDER=ollama)
# OPENAI_API_BASE=http://localhost:11434/v1
# LLM_MODEL=llama3

# Custom OpenAI-compatible endpoint
# LLM_CUSTOM_BASE_URL=http://your-server:8000/v1
# LLM_CUSTOM_API_KEY=your-api-key
# LLM_MODEL=your-model-name

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Telegram Bot ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── WhatsApp Business API ────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=rovot-whatsapp-verify
WHATSAPP_APP_SECRET=

# ── Signal Messenger ─────────────────────────────────────────────────
SIGNAL_API_URL=http://localhost:8080
SIGNAL_PHONE_NUMBER=
SIGNAL_WEBHOOK_SECRET=

# ── OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Ports (Docker Compose) ───────────────────────────────────────────
BACKEND_PORT=5000
FRONTEND_PORT=3000
DB_PORT=5432
SIGNAL_PORT=8080

# ── Flask ────────────────────────────────────────────────────────────
FLASK_ENV=production
